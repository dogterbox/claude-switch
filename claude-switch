#!/usr/bin/env bash
# claude-switch — Switch Claude Code accounts (macOS only)
#
# Each profile is a directory under ~/.claude-profiles/<name>/ plus a
# matching macOS Keychain entry "Claude Code-credentials-<name>".
# Switching swaps both the directory symlink (~/.claude) and the active
# keychain entry ("Claude Code-credentials"), so the next `claude` session
# uses a different account without manual login.

set -euo pipefail

BASE_DIR="$HOME/.claude-profiles"
TARGET_LINK="$HOME/.claude"
ACTIVE_KEY="Claude Code-credentials"
KEY_PREFIX="Claude Code-credentials-"
CLAUDE_JSON="$HOME/.claude.json"
ACCOUNT_FILE=".account.json"
ROOT_BAK_FILE=".claude-root.json"

# OAuth refresh — recovered from Claude Code binary v2.1.186 (function `mQ`).
# These are undocumented internals and may change in a future Claude release.
OAUTH_TOKEN_URL="https://platform.claude.com/v1/oauth/token"
OAUTH_CLIENT_ID="9d1c250a-e61b-44d9-88ed-5944d1962f5e"
# Refresh when the token expires within this many seconds.
TOKEN_REFRESH_SKEW=60

die()  { printf '\xe2\x9d\x8c %s\n' "$*" >&2; exit 1; }
warn() { printf '\xe2\x9a\xa0\xef\xb8\x8f  %s\n' "$*" >&2; }
ok()   { printf '\xe2\x9c\x85 %s\n' "$*"; }
info() { printf '\xe2\x84\xb9\xef\xb8\x8f  %s\n' "$*"; }

require_macos() {
    [[ "$(uname -s)" == "Darwin" ]] || die "claude-switch supports macOS only"
}

current_profile() {
    if [[ -L "$TARGET_LINK" ]]; then
        basename "$(readlink "$TARGET_LINK")"
    else
        echo "(none)"
    fi
}

# ---------- Keychain helpers ----------------------------------------------

kc_read() {
    # $1 = service name; prints password to stdout, empty if not found
    security find-generic-password -s "$1" -w 2>/dev/null || true
}

kc_exists() {
    security find-generic-password -s "$1" >/dev/null 2>&1
}

kc_save() {
    # $1 = service name, $2 = password
    local service="$1" password="$2"
    [[ -z "$password" ]] && return 1
    # Delete-then-add so ACL is reset cleanly. -A trusts any app permanently
    # (strategy B: no prompt every time Claude Code reads).
    security delete-generic-password -s "$service" >/dev/null 2>&1 || true
    security add-generic-password -s "$service" -a "$USER" -w "$password" -A
}

kc_delete() {
    security delete-generic-password -s "$1" >/dev/null 2>&1 || true
}

# ---------- Parallel mode: token refresh engine ---------------------------
#
# Parallel mode runs Claude Code with a per-process CLAUDE_CODE_OAUTH_TOKEN
# (which overrides the global Keychain at runtime) plus a per-process
# CLAUDE_CONFIG_DIR. This lets multiple windows use different accounts
# simultaneously without touching the active Keychain slot or the symlink.
#
# OAuth access tokens expire (~24h) and the refresh token ROTATES on every
# refresh, so a fresh refresh token must be written back to the profile's
# Keychain backup slot or the next refresh fails. All parallel-mode commands
# go through profile_access_token().

require_jq() {
    has_jq || die "This command needs 'jq' (brew install jq)"
}

now_ms() {
    # Bash 3.2 has no millisecond clock; use python3 (present on macOS).
    python3 -c 'import time;print(int(time.time()*1000))'
}

# Acquire a per-profile lock (atomic mkdir; bash 3.2 has no flock).
# Waits up to ~10s, then assumes a stale lock and proceeds.
refresh_lock() {
    local lock="$BASE_DIR/$1/.refresh.lock"
    local i=0
    while ! mkdir "$lock" 2>/dev/null; do
        i=$((i + 1))
        [[ $i -ge 20 ]] && { rm -rf "$lock" 2>/dev/null; mkdir "$lock" 2>/dev/null; break; }
        sleep 0.5
    done
    REFRESH_LOCK_DIR="$lock"
}

refresh_unlock() {
    [[ -n "${REFRESH_LOCK_DIR:-}" ]] && rm -rf "$REFRESH_LOCK_DIR" 2>/dev/null
    REFRESH_LOCK_DIR=""
}

# POST the refresh token; on success rewrite the Keychain backup blob.
# Echoes the new access token on stdout. Returns non-zero on hard failure.
do_refresh() {
    local name="$1" blob="$2"
    local rt; rt="$(printf '%s' "$blob" | jq -r '.claudeAiOauth.refreshToken // empty')"
    [[ -n "$rt" ]] || return 2   # no refresh token → caller must re-login

    local body resp http
    body="$(jq -nc --arg rt "$rt" --arg cid "$OAUTH_CLIENT_ID" \
        '{grant_type:"refresh_token",refresh_token:$rt,client_id:$cid}')"

    local attempt=0 delay=2
    while [[ $attempt -lt 3 ]]; do
        attempt=$((attempt + 1))
        resp="$(curl -s -w $'\n%{http_code}' -X POST "$OAUTH_TOKEN_URL" \
            -H "Content-Type: application/json" -d "$body" 2>/dev/null)"
        http="${resp##*$'\n'}"
        resp="${resp%$'\n'*}"
        case "$http" in
            200) break ;;
            429) sleep "$delay"; delay=$((delay * 2)); continue ;;
            *)   return 3 ;;   # invalid_grant / other → re-login needed
        esac
    done
    [[ "$http" == "200" ]] || return 3

    local new_at new_rt new_exp exp_ms
    new_at="$(printf '%s' "$resp" | jq -r '.access_token // empty')"
    new_rt="$(printf '%s' "$resp" | jq -r '.refresh_token // empty')"
    new_exp="$(printf '%s' "$resp" | jq -r '.expires_in // empty')"
    [[ -n "$new_at" ]] || return 3
    [[ -n "$new_rt" ]] || new_rt="$rt"           # fall back if not rotated
    exp_ms="$(( $(now_ms) + ${new_exp:-3600} * 1000 ))"

    # Rebuild the blob preserving every other field (trustedDeviceToken, etc.)
    local new_blob
    new_blob="$(printf '%s' "$blob" | jq -c \
        --arg at "$new_at" --arg rt "$new_rt" --argjson exp "$exp_ms" \
        '.claudeAiOauth.accessToken=$at
         | .claudeAiOauth.refreshToken=$rt
         | .claudeAiOauth.expiresAt=$exp')"
    kc_save "$KEY_PREFIX$name" "$new_blob" >/dev/null 2>&1
    printf '%s' "$new_at"
}

# Resolve a fresh access token for <profile>. Refreshes if expired.
# Echoes the access token; dies with a clear message if unrecoverable.
profile_access_token() {
    local name="$1"
    [[ -d "$BASE_DIR/$name" ]] || die "Profile '$name' not found (claude-switch list)"
    kc_exists "$KEY_PREFIX$name" \
        || die "Profile '$name' has no saved token — run 'claude-switch use $name' and log in first"

    refresh_lock "$name"
    trap refresh_unlock EXIT

    local blob exp now at
    blob="$(kc_read "$KEY_PREFIX$name")"
    exp="$(printf '%s' "$blob" | jq -r '.claudeAiOauth.expiresAt // 0')"
    now="$(now_ms)"

    if [[ "$exp" -gt $(( now + TOKEN_REFRESH_SKEW * 1000 )) ]]; then
        at="$(printf '%s' "$blob" | jq -r '.claudeAiOauth.accessToken // empty')"
    else
        local rc=0
        at="$(do_refresh "$name" "$blob")" || rc=$?
        if [[ $rc -ne 0 || -z "$at" ]]; then
            refresh_unlock; trap - EXIT
            die "Could not refresh token for '$name' — run 'claude-switch use $name' and log in to Claude Code"
        fi
    fi

    refresh_unlock
    trap - EXIT
    [[ -n "$at" ]] || die "No token available for '$name'"
    printf '%s' "$at"
}

# ---------- Account info (from ~/.claude.json oauthAccount) ---------------

has_jq() { command -v jq >/dev/null 2>&1; }

# Stash the current account info (from ~/.claude.json) into <profile>/.account.json
account_stash() {
    local name="$1"
    has_jq                                 || return 0
    [[ -d "$BASE_DIR/$name" ]]             || return 0
    [[ -r "$CLAUDE_JSON" ]]                || return 0
    local oa
    oa="$(jq -c '.oauthAccount // empty' "$CLAUDE_JSON" 2>/dev/null)" || return 0
    [[ -n "$oa" && "$oa" != "null" ]]      || return 0
    local target="$BASE_DIR/$name/$ACCOUNT_FILE"
    printf '%s\n' "$oa" > "$target.tmp" && mv "$target.tmp" "$target"
}

# Snapshot the entire ~/.claude.json (Claude Code's account-cache file) into the profile.
# This is the file Claude Code reads on launch for oauthAccount, /status, /usage, etc.
# Without swapping it, switching tokens alone leaves stale account info visible.
root_stash() {
    local name="$1"
    [[ -d "$BASE_DIR/$name" ]] || return 0
    [[ -r "$CLAUDE_JSON" ]]    || return 0
    local target="$BASE_DIR/$name/$ROOT_BAK_FILE"
    cp -p "$CLAUDE_JSON" "$target.tmp" && mv "$target.tmp" "$target"
}

# Restore <profile>/.claude-root.json into ~/.claude.json. If the profile has no
# snapshot yet (first-time switch), remove ~/.claude.json so Claude Code starts
# fresh on the next launch (avoids carrying the previous profile's cache).
root_restore() {
    local name="$1"
    local src="$BASE_DIR/$name/$ROOT_BAK_FILE"
    if [[ -r "$src" ]]; then
        cp -p "$src" "$CLAUDE_JSON.tmp" && mv "$CLAUDE_JSON.tmp" "$CLAUDE_JSON"
    else
        rm -f "$CLAUDE_JSON"
    fi
}

# Look up a field from a profile's stash; fall back to ~/.claude.json if it's the active one.
account_field() {
    local name="$1" field="$2"
    has_jq || return 0
    local f="$BASE_DIR/$name/$ACCOUNT_FILE"
    if [[ -r "$f" ]]; then
        jq -r --arg k "$field" '.[$k] // empty' "$f" 2>/dev/null
        return 0
    fi
    if [[ "$name" == "$(current_profile)" && -r "$CLAUDE_JSON" ]]; then
        jq -r --arg k "$field" '.oauthAccount[$k] // empty' "$CLAUDE_JSON" 2>/dev/null
    fi
}

# ---------- Safety --------------------------------------------------------

claude_running() {
    pgrep -f "/claude " >/dev/null 2>&1 \
        || pgrep -fl "Claude.app/Contents/MacOS" >/dev/null 2>&1 \
        || pgrep -x "claude" >/dev/null 2>&1
}

# ---------- Commands ------------------------------------------------------

cmd_create() {
    local name="${1:-}"
    [[ -z "$name" ]]                    && die "Usage: claude-switch create <name>"
    [[ "$name" =~ ^[A-Za-z][A-Za-z0-9_-]*$ ]] || die "Profile name must start with a letter and contain only [A-Za-z0-9_-]"
    [[ ${#name} -le 20 ]]              || die "Profile name must be 20 characters or fewer"
    [[ -d "$BASE_DIR/$name" ]]          && die "Profile '$name' already exists"
    mkdir -p "$BASE_DIR/$name"
    ok "Created profile '$name' (at $BASE_DIR/$name)"
    info "First use: run 'claude-switch use $name', then open Claude Code to log in — the token will be saved automatically when you switch away."
}

cmd_list() {
    local current; current="$(current_profile)"
    echo "📁 Claude Profiles:"

    if [[ ! -d "$BASE_DIR" ]]; then
        info "No profiles yet — create one with: claude-switch create <name>"
        return 0
    fi

    # First pass: find longest name for column alignment
    local max_len=4
    for dir in "$BASE_DIR"/*/; do
        [[ -d "$dir" ]] || continue
        local n; n="$(basename "$dir")"
        [[ ${#n} -gt $max_len ]] && max_len=${#n}
    done

    # Second pass: print
    local found=0
    for dir in "$BASE_DIR"/*/; do
        [[ -d "$dir" ]] || continue
        found=1
        local name; name="$(basename "$dir")"
        local email; email="$(account_field "$name" emailAddress)"
        local suffix=""
        if [[ "$name" == "$current" ]]; then
            [[ -n "$email" ]] && suffix="👤  $email"
            printf '  ⭐️  %-*s  %s\n' "$max_len" "$name" "$suffix"
        else
            if kc_exists "$KEY_PREFIX$name"; then
                [[ -n "$email" ]] && suffix="👤  $email"
            else
                suffix="[login required]"
            fi
            printf '  -   %-*s  %s\n' "$max_len" "$name" "$suffix"
        fi
    done

    [[ $found -eq 0 ]] && info "No profiles yet — create one with: claude-switch create <name>"
}

cmd_status() {
    local cur; cur="$(current_profile)"
    local token_status
    if kc_exists "$ACTIVE_KEY"; then token_status="active"; else token_status="missing (login required)"; fi
    printf '⭐️  %-10s  %s\n' "Profile" "$cur"
    printf '🔑  %-10s  %s\n' "Token" "$token_status"
    if [[ "$cur" != "(none)" ]]; then
        local email org role
        email="$(account_field "$cur" emailAddress)"
        org="$(account_field "$cur" organizationName)"
        role="$(account_field "$cur" organizationRole)"
        [[ -n "$email" ]] && printf '👤  %-10s  %s\n' "Account" "$email"
        [[ -n "$org"   ]] && printf '🏢  %-10s  %s\n' "Org" "$org${role:+ ($role)}"
    fi
}

cmd_switch() {
    local name="${1:-}"
    local force=0
    [[ "${2:-}" == "--force" ]] && force=1
    [[ -z "$name" ]]            && die "Usage: claude-switch use <name> [--force]"
    [[ -d "$BASE_DIR/$name" ]]  || die "Profile '$name' not found (list with: claude-switch list)"

    local current; current="$(current_profile)"
    if [[ "$name" == "$current" ]]; then
        ok "Already on profile '$name'"
        return 0
    fi

    if claude_running && [[ $force -eq 0 ]]; then
        warn "Claude Code is running — close it first, or pass --force"
        return 1
    fi

    # 1) Snapshot current active token + ~/.claude.json + oauthAccount → current profile
    if [[ "$current" != "(none)" ]]; then
        if kc_exists "$ACTIVE_KEY"; then
            local active_tok; active_tok="$(kc_read "$ACTIVE_KEY")"
            if [[ -n "$active_tok" ]]; then
                kc_save "$KEY_PREFIX$current" "$active_tok"
            fi
        fi
        account_stash "$current" || true
        root_stash "$current"    || true
    fi

    # 2) Restore target profile's token → active slot (or clear if none)
    if kc_exists "$KEY_PREFIX$name"; then
        local target_tok; target_tok="$(kc_read "$KEY_PREFIX$name")"
        kc_save "$ACTIVE_KEY" "$target_tok"
    else
        kc_delete "$ACTIVE_KEY"
        info "Profile '$name' has no saved token — log in to Claude Code after switching"
    fi

    # 3) Restore target profile's ~/.claude.json snapshot (or remove if none)
    root_restore "$name" || true

    # 4) Swap directory symlink
    if [[ -e "$TARGET_LINK" && ! -L "$TARGET_LINK" ]]; then
        die "$TARGET_LINK exists and is not a symlink — move it aside first"
    fi
    rm -f "$TARGET_LINK"
    ln -s "$BASE_DIR/$name" "$TARGET_LINK"

    ok "Switched to profile '$name'"
}

cmd_rename() {
    local old="${1:-}" new="${2:-}"
    [[ -z "$old" || -z "$new" ]]  && die "Usage: claude-switch rename <old> <new>"
    [[ "$new" =~ ^[A-Za-z][A-Za-z0-9_-]*$ ]] || die "Profile name must start with a letter and contain only [A-Za-z0-9_-]"
    [[ ${#new} -le 20 ]]               || die "Profile name must be 20 characters or fewer"
    [[ -d "$BASE_DIR/$old" ]]     || die "Profile '$old' not found"
    [[ -d "$BASE_DIR/$new" ]]     && die "Profile '$new' already exists"
    [[ "$old" == "$(current_profile)" ]] && die "Cannot rename the active profile — switch away first"

    mv "$BASE_DIR/$old" "$BASE_DIR/$new"

    if kc_exists "${KEY_PREFIX}${old}"; then
        local tok; tok="$(kc_read "${KEY_PREFIX}${old}")"
        kc_save "${KEY_PREFIX}${new}" "$tok"
        kc_delete "${KEY_PREFIX}${old}"
    fi

    ok "Renamed profile '$old' → '$new'"
}

cmd_delete() {
    local name="${1:-}"
    [[ -z "$name" ]]                        && die "Usage: claude-switch delete <name>"
    [[ "$name" == "legacy" ]]               && die "Cannot delete 'legacy' (reserved)"
    [[ "$name" == "$(current_profile)" ]]   && die "Cannot delete the active profile — switch away first"
    [[ -d "$BASE_DIR/$name" ]]              || die "Profile '$name' not found"

    kc_delete "$KEY_PREFIX$name"
    rm -rf "$BASE_DIR/$name"
    ok "Deleted profile '$name'"
}

# ---------- Parallel-mode commands ----------------------------------------

# Resolve the claude binary to exec (used by `run` and the wrapper script).
claude_bin() {
    if [[ -n "${CLAUDE_CODE_EXECPATH:-}" && -x "$CLAUDE_CODE_EXECPATH" ]]; then
        printf '%s' "$CLAUDE_CODE_EXECPATH"
    else
        command -v claude || die "claude binary not found in PATH"
    fi
}

cmd_env() {
    require_jq
    local name="${1:-}"
    [[ -z "$name" ]] && die "Usage: claude-switch env <profile>"
    local tok; tok="$(profile_access_token "$name")"
    printf 'export CLAUDE_CONFIG_DIR=%q\n' "$BASE_DIR/$name"
    printf 'export CLAUDE_CODE_OAUTH_TOKEN=%q\n' "$tok"
}

cmd_run() {
    require_jq
    local name="${1:-}"; shift || true
    [[ -z "$name" ]] && die "Usage: claude-switch run <profile> [-- <cmd...>]"
    [[ "${1:-}" == "--" ]] && shift
    local tok; tok="$(profile_access_token "$name")"
    export CLAUDE_CONFIG_DIR="$BASE_DIR/$name"
    export CLAUDE_CODE_OAUTH_TOKEN="$tok"
    if [[ $# -eq 0 ]]; then
        exec "$(claude_bin)"
    else
        exec "$@"
    fi
}

cmd_refresh() {
    require_jq
    local name="${1:-}"
    [[ -z "$name" ]] && die "Usage: claude-switch refresh <profile>"
    profile_access_token "$name" >/dev/null
    ok "Token for '$name' is fresh"
}

cmd_wrapper() {
    require_jq
    local name="${1:-}"
    [[ -z "$name" ]] && die "Usage: claude-switch wrapper <profile>"
    [[ -d "$BASE_DIR/$name" ]] || die "Profile '$name' not found (claude-switch list)"
    local self; self="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
    local script="$BASE_DIR/$name/launch"
    cat > "$script.tmp" <<EOF
#!/usr/bin/env bash
# Auto-generated by claude-switch — launches Claude Code as profile '$name'.
# No token is stored here; it is read (and refreshed) from Keychain at launch.
# Use as VS Code "claudeCode.claudeProcessWrapper".
exec "$self" run $name -- "\$@"
EOF
    chmod 0755 "$script.tmp" && mv "$script.tmp" "$script"
    printf '%s\n' "$script"
}

cmd_help() {
    cat <<'EOF'
🛠️  claude-switch — Switch Claude Code accounts (macOS)

Usage:
  claude-switch create <name>               Create a new empty profile
  claude-switch list                        List all profiles
  claude-switch status                      Show the active profile + account info
  claude-switch use <name> [--force]        Switch to profile <name>
                                            (--force if Claude Code is running)
  claude-switch rename <old> <new>          Rename a profile
  claude-switch delete <name>               Delete a profile (directory + token)
  claude-switch help                        Show this message

Parallel mode (run multiple accounts at once, needs jq):
  claude-switch env <profile>               Print export lines for a profile
                                            (eval "$(claude-switch env work)")
  claude-switch run <profile> [-- <cmd>]    Run claude (or <cmd>) as <profile>
  claude-switch refresh <profile>           Refresh a profile's token now
  claude-switch wrapper <profile>           Make a launcher for VS Code's
                                            claudeCode.claudeProcessWrapper

Notes:
  - Each profile holds its own token in macOS Keychain — real account switching
  - 'use' swaps the single active login; parallel mode runs many at once via
    per-process CLAUDE_CODE_OAUTH_TOKEN + CLAUDE_CONFIG_DIR (no Keychain swap)
  - 'legacy' is the reserved default profile
  - Keychain ACL is set to "trust all apps" so saves/restores never prompt
EOF
}

# ---------- Entry ---------------------------------------------------------

require_macos

case "${1:-help}" in
    create)            shift; cmd_create "${1:-}" ;;
    list)              cmd_list ;;
    status)            cmd_status ;;
    use)               shift; cmd_switch "${1:-}" "${2:-}" ;;
    rename)            shift; cmd_rename "${1:-}" "${2:-}" ;;
    delete)            shift; cmd_delete "${1:-}" ;;
    env)               shift; cmd_env "${1:-}" ;;
    run)               shift; cmd_run "$@" ;;
    refresh)           shift; cmd_refresh "${1:-}" ;;
    wrapper)           shift; cmd_wrapper "${1:-}" ;;
    help|-h|--help)    cmd_help ;;
    *)                 cmd_help; exit 1 ;;
esac
